{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "resolveJsonModule": false,
    "skipLibCheck": true,
    "strict": true
  },
  "include": ["mcp-server.ts"],
  "exclude": ["node_modules", ".next", "dist"]
}
